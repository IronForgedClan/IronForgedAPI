meta {
  name: Get Member
  type: http
  seq: 2
}

get {
  url: {{base_url}}/members/123456789012345678
  body: none
  auth: none
}

headers {
  Authorization: Bearer {{token}}
}

docs {
  Requires perm: members:read
  Path params:
    discord_id - the member's Discord snowflake ID
  Returns 404 if no member with that discord_id.
}

tests {
  test("status 200 or 404", function() {
    expect([200, 404]).to.include(res.status);
  });
}
