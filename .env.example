ENVIRONMENT=dev/prod

LOG_LEVEL=INFO
LOG_DIR=./logs
LOG_FILE_MAX_BYTES=10000000
LOG_FILE_BACKUP_COUNT=10
LOG_CONSOLE_LEVEL=
LOG_JSON_FORMAT=false

# Env vars read by ironforgedcore.config.BaseConfig. The api only needs
# a subset, but BaseConfig still validates these at import time.
TEMP_DIR=
GUILD_ID=
BOT_TOKEN=

WOM_API_KEY=
WOM_GROUP_ID=

# Both must be set to enable LTM tracking
WOM_LTM_BASE_URL=
WOM_LTM_GROUP_ID=

AUTOMATION_CHANNEL_ID=
RAFFLE_CHANNEL_ID=
INGOT_SHOP_CHANNEL_ID=
RULES_CHANNEL_ID=
RANKINGS_CHANNEL_ID=
BOT_COMMANDS_CHANNEL_ID=
BOT_CHANGELOG_CHANNEL_ID=
CREATE_TICKET_CHANNEL_ID=

DB_ROOT=
DB_USER=
DB_PASS=
DB_NAME=api_test

API_HOST=0.0.0.0
API_PORT=8080
API_RATE_LIMIT=30
API_TRUSTED_HOSTS=127.0.0.1
API_CORS_ORIGINS=
